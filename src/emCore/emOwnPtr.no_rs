    - emOwnPtrBase& operator=(OBJECT* ptr)           // assign new ptr, delete old
    - void Reset()                                   // Set(NULL)
    - OBJECT* Release()                              // release ownership, return raw ptr
    - operator OBJECT*() const                       // implicit conversion to raw ptr
    - OBJECT* Get() const                            // get raw ptr
