  - template<class OBJECT> struct emOwnPtrDeleter
    - void operator()(OBJECT* ptr) const             // calls delete ptr

  - template<class OBJECT> struct emOwnArrayPtrDeleter
    - void operator()(OBJECT* ptr) const             // calls delete[] ptr

  - template<class OBJECT> class emOwnPtr : public emOwnPtrBase<OBJECT, emOwnPtrDeleter<OBJECT>>
    - emOwnPtr(OBJECT* ptr = NULL)
    - emOwnPtr& operator=(OBJECT* ptr)

  - template<class OBJECT> class emOwnArrayPtr : public emOwnPtrBase<OBJECT, emOwnArrayPtrDeleter<OBJECT>>
