  - emSortArray<OBJ>(OBJ* array, int count, compare_fn, void* context) -> bool
  - emBinarySearch<OBJ,KEY>(const OBJ* array, int count, KEY key, compare_fn, void* context) -> int

  class emArray<OBJ>:
  - emArray() -- default constructor (empty array)
  - emArray(const emArray &) -- copy constructor (COW shallow copy)
  - emArray(const OBJ* array, int count, int tuningLevel=0) -- construct from C array
  - emArray(const OBJ* array, int count, const OBJ* array2, int count2, int tuningLevel=0) -- construct by concatenating two arrays
