Rust file: src/emCore/toolkit_images.rs

Defines:
  - struct ToolkitImages (pub(crate)): holds 15 emImage fields for widget TGA assets
    Fields: group_border, button_border, popup_border, group_inner_border,
            io_field, custom_rect_border, button, button_pressed, button_checked,
            splitter, splitter_pressed, check_box, check_box_pressed,
            radio_box, radio_box_pressed
  - fn with_toolkit_images<R>(f: impl FnOnce(&ToolkitImages) -> R) -> R (pub(crate)):
    thread-local lazy-init accessor; loads all 15 TGA images on first call via OnceCell
  - fn decode(data, name, expected_w, expected_h) -> emImage (private):
    wrapper around load_tga() with dimension assertion

